# =============================================================================
# RAYE API Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running the application.
# =============================================================================

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (REQUIRED)
# -----------------------------------------------------------------------------
# Get these from your Supabase dashboard: Project Settings > Database > Connection string
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT-REF].supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# JWT AUTHENTICATION (REQUIRED)
# -----------------------------------------------------------------------------
# Generate secure random strings for these values
# You can use: openssl rand -base64 32
JWT_SECRET="your-256-bit-secret"
JWT_EXPIRY="15m"
JWT_REFRESH_SECRET="your-other-secret"
JWT_REFRESH_EXPIRY="7d"

# -----------------------------------------------------------------------------
# REDIS CONFIGURATION (REQUIRED)
# -----------------------------------------------------------------------------
# Get this from your Redis provider (e.g., Upstash, Redis Cloud, or local Redis)
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# ENCRYPTION CONFIGURATION (REQUIRED)
# -----------------------------------------------------------------------------
# Generate a secure 256-bit encryption key for field-level encryption
# Use: openssl rand -hex 32
# This key is used to encrypt sensitive data like emails and tokens at rest
ENCRYPTION_KEY="your-256-bit-encryption-key-here"
# Optional: Generate a salt for key derivation (will be generated automatically if not provided)
# Use: openssl rand -hex 32
# ENCRYPTION_SALT="your-32-byte-salt-here"

# -----------------------------------------------------------------------------
# TREE-SITTER CACHE CONFIGURATION (OPTIONAL)
# -----------------------------------------------------------------------------
# Directory for caching parsed AST files to improve performance
# Default: /tmp/tree-sitter-cache
# Set to a persistent directory for better performance across restarts
TREE_SITTER_CACHE_DIR="/tmp/tree-sitter-cache"

# -----------------------------------------------------------------------------
# AI/ML ORCHESTRATION CONFIGURATION (OPTIONAL)
# -----------------------------------------------------------------------------
# OpenAI API key for embeddings and advanced LLM features
# Get this from https://platform.openai.com/api-keys
# Leave empty to use only Gemini API for LLM orchestration
OPENAI_API_KEY=sk-optional-for-embeddings

# Vector database URL for semantic search and embeddings storage
# Default: Redis connection string
# Configure for external vector databases like Pinecone, Weaviate, etc.
VECTOR_DB_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# AI SERVICES (REQUIRED)
# -----------------------------------------------------------------------------
# Get this from Google AI Studio: https://aistudio.google.com/app/apikey
# Create a new API key for Gemini 2.0 Flash
GEMINI_API_KEY="your-new-key-here"

# -----------------------------------------------------------------------------
# OPTIONAL: PORT CONFIGURATION
# -----------------------------------------------------------------------------
# Port for the API server (default: 3001)
# PORT=3001

# -----------------------------------------------------------------------------
# OPTIONAL: LOGGING
# -----------------------------------------------------------------------------
# Log level (default: info)
# LOG_LEVEL=debug|info|warn|error

# =============================================================================
# FRONTEND ENVIRONMENT VARIABLES (apps/web/.env.local)
# =============================================================================
# These go in the frontend .env.local file, not this file

# API URL for the frontend
# NEXT_PUBLIC_API_URL="http://localhost:3001"

# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Fill in the required values:
#    - DATABASE_URL and DIRECT_URL from Supabase
#    - JWT_SECRET and JWT_REFRESH_SECRET (generate new ones)
#    - REDIS_URL from your Redis provider
#    - ENCRYPTION_KEY (generate with: openssl rand -hex 32)
#    - GEMINI_API_KEY from Google AI Studio
#
# 3. Run database migrations:
#    pnpm db:migrate
#
# 4. Start the application:
#    pnpm dev
#
# =============================================================================
# WHERE TO GET THE VALUES:
# =============================================================================
# • Supabase Database: https://supabase.com/dashboard
#   → Project Settings → Database → Connection string
#
# • JWT Secrets: Generate your own secure random strings
#   Use: openssl rand -base64 32
#
# • Redis: https://upstash.com/ or https://redis.com/
#   → Get your Redis connection URL
#
# • Gemini API: https://aistudio.google.com/app/apikey
#   → Create API key for Gemini 2.0 Flash
#
# =============================================================================
